# Pick ONE provider block below and uncomment it (all 3-4 lines of that block).
# Keep every other block commented out — the loader uses first-value-wins, so a
# stray uncommented LLM_BASE_URL from another block would silently override yours.
# All providers below are OpenAI-compatible chat/completions endpoints.
# Note: an explicit provider from config.yaml (llm.provider) or CLI (--provider)
# takes precedence over LLM_PROVIDER here.

# === DeepSeek（默认示例）===
# LLM_PROVIDER=deepseek
# LLM_API_KEY=your_deepseek_api_key_here
# LLM_BASE_URL=https://api.deepseek.com/v1
# LLM_MODEL=deepseek-v4-flash
# 如需更强推理，可按 DeepSeek 当前官方文档改用 deepseek-v4-pro。

# === Kimi / Moonshot ===
# LLM_PROVIDER=kimi
# LLM_API_KEY=your_kimi_api_key_here
# LLM_BASE_URL=https://api.moonshot.cn/v1
# LLM_MODEL=moonshot-v1-128k

# === Zhipu GLM ===
# LLM_PROVIDER=glm
# LLM_API_KEY=your_glm_api_key_here
# LLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4
# LLM_MODEL=glm-4-flash

# === Alibaba Qwen / DashScope ===
# LLM_PROVIDER=qwen
# LLM_API_KEY=your_qwen_api_key_here
# LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# LLM_MODEL=qwen-plus

# === OpenAI, or any OpenAI-compatible provider ===
# LLM_PROVIDER=openai
# LLM_API_KEY=your_openai_api_key_here
# LLM_BASE_URL=https://api.openai.com/v1
# LLM_MODEL=gpt-4o-mini

# Optional proxy for YouTube / RSS / podcast audio downloads (not LLM calls).
# Semantics:
#   unset / empty / none  -> no proxy (default)
#   auto                  -> scan localhost ports 12345-12350 for a SOCKS5 proxy
#   any other value       -> used as-is, e.g. socks5://127.0.0.1:1080
# SOCKS proxies require the PySocks extra: pip install "requests[socks]"
# (already included via requirements.txt).
# PODCAST_PROXY=socks5://127.0.0.1:1080

# Whisper auto-transcription is configured in pod2wiki.config.yaml under the
# `whisper:` block (model, clip_seconds, auto_threshold, language). Requires the
# optional `faster-whisper` Python package and `ffmpeg` on PATH; the run
# degrades to the RSS description if either is missing. Leave `language` unset
# to let Whisper auto-detect (recommended for mixed Chinese/English feeds).
